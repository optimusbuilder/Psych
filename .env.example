# Frontend (Vite)
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:4000

# Backend (planned)
NODE_ENV=development
API_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_cura
REDIS_URL=redis://localhost:6379/0

# Auth + security
JWT_ISSUER=project-cura
JWT_AUDIENCE=project-cura-web
JWT_PUBLIC_KEY=replace-with-public-key
AUDIT_HASH_SALT=replace-with-random-salt

# Clinical engine
TRIAGE_ENGINE_VERSION=v1.0.0
DEFAULT_ORGANIZATION_ID=demo-org

# LLM helper layer (summaries/extraction only)
LLM_SUMMARY_MODEL=gpt-4.1-mini
